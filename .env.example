# Runtime
NODE_ENV=development
PORT=5000

# MongoDB
# Use a replica set when you need MongoDB transactions.
MONGO_URI=mongodb://localhost:27017/digital_products_platform

# Authentication
JWT_SECRET=replace-with-a-long-random-development-secret
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Application URLs
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173
FRONTEND_VERIFY_REDIRECT_URL=http://localhost:5173/email-verified
ALLOWED_ORIGINS=http://localhost:5173

# Email / SMTP
# Leave blank in local development if you do not need outbound email.
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@example.com

# Google OAuth
# Optional. Routes return 503 until both values are configured.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Exchange rates
EXCHANGE_RATE_API_URL=https://api.exchangerate.host/latest?base=USD
EXCHANGE_RATE_API_KEY=
EXCHANGE_RATE_TIMEOUT_MS=10000

# Provider sync and polling tuning
POLL_BATCH_LIMIT=100
POLL_MAX_BATCH_SIZE=50
POLL_MAX_CONCURRENT=3
POLL_INTER_BATCH_DELAY_MS=0
SYNC_UPSERT_CONCURRENCY=10
PROVIDER_PRICE_CACHE_TTL_MS=300000
