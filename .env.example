# Runtime
NODE_ENV=development
PORT=5000

# MongoDB
# Use a replica set when you need MongoDB transactions.
MONGO_URI=mongodb://localhost:27017/digital_products_platform

# Authentication
JWT_SECRET=replace-with-a-long-random-development-secret
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Application URLs
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173
FRONTEND_VERIFY_REDIRECT_URL=http://localhost:5173/email-verified
ALLOWED_ORIGINS=http://localhost:5173

# Email / SMTP
# Leave blank in local development if you do not need outbound email.
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@example.com

# Google OAuth
# Optional. Routes return 503 until both values are configured.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Exchange rates
EXCHANGE_RATE_API_URL=https://api.exchangerate.host/latest?base=USD
EXCHANGE_RATE_API_KEY=
EXCHANGE_RATE_TIMEOUT_MS=10000

# Payments base module
# Wallet top-up intents. MOCK is safe for local development.
PAYMENTS_ENABLED=true
PAYMENT_DEFAULT_GATEWAY=MOCK
PAYMENT_ALLOWED_GATEWAYS=MOCK
PAYMENT_MIN_AMOUNT=1
PAYMENT_MAX_AMOUNT=10000
MOCK_PAYMENT_CHECKOUT_BASE_URL=http://localhost:5173/mock-payment

# Network International / N-Genius Hosted Payment Page.
# Do not put production credentials in source control.
NETWORK_INTERNATIONAL_ENABLED=true
NETWORK_INTERNATIONAL_ENV=live
NETWORK_INTERNATIONAL_BASE_URL=
NETWORK_INTERNATIONAL_API_KEY=
NETWORK_INTERNATIONAL_OUTLET_REF=
NETWORK_INTERNATIONAL_CURRENCY=AED
NETWORK_INTERNATIONAL_RETURN_URL=http://127.0.0.1:5173/payment/success
NETWORK_INTERNATIONAL_CANCEL_URL=http://127.0.0.1:5173/payment/cancel
NETWORK_INTERNATIONAL_WEBHOOK_SECRET=
NETWORK_INTERNATIONAL_WEBHOOK_SECRET_HEADER=x-network-webhook-secret

# Paymento hosted USDT wallet top-up checkout.
# Secrets are backend-only. Add PAYMENTO to PAYMENT_ALLOWED_GATEWAYS to enable selection.
PAYMENTO_ENABLED=false
PAYMENTO_API_BASE_URL=https://api.paymento.io
PAYMENTO_API_KEY=
PAYMENTO_IPN_SECRET=
PAYMENTO_RETURN_URL=http://localhost:5173/payment/success
PAYMENTO_CANCEL_URL=http://localhost:5173/payment/cancel
PAYMENTO_PENDING_URL=http://localhost:5173/payment/pending
PAYMENTO_IPN_URL=http://localhost:5000/api/webhooks/payments/paymento
PAYMENTO_FIAT_CURRENCY=USD
PAYMENTO_ALLOWED_CRYPTO=USDT
PAYMENTO_RISK_SPEED=1
# Optional endpoint path overrides for the Paymento merchant API.
PAYMENTO_CREATE_PATH=/v1/payment/request
PAYMENTO_VERIFY_PATH=/v1/payment/verify

# Ziina hosted wallet top-up checkout.
# Secrets are backend-only. Add ZIINA to PAYMENT_ALLOWED_GATEWAYS to enable selection.
ZIINA_ENABLED=false
ZIINA_API_BASE_URL=https://api-v2.ziina.com/api
ZIINA_ACCESS_TOKEN=
ZIINA_CURRENCY=AED
ZIINA_TEST_MODE=true
ZIINA_SUCCESS_URL=https://winniefun.com/payment/success?provider=ziina&payment_intent_id={PAYMENT_INTENT_ID}
ZIINA_CANCEL_URL=https://winniefun.com/payment/cancel?provider=ziina&payment_intent_id={PAYMENT_INTENT_ID}
ZIINA_FAILURE_URL=https://winniefun.com/payment/cancel?provider=ziina&payment_intent_id={PAYMENT_INTENT_ID}
ZIINA_WEBHOOK_URL=https://winniefun.com/api/webhooks/payments/ziina
ZIINA_WEBHOOK_SECRET=

# Future payment gateway placeholders.
TAP_SECRET_KEY=

# Provider sync and polling tuning
#
# Provider credential encryption key. Required before creating/updating
# providers with credentials or calling provider APIs.
# Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PROVIDER_CREDENTIALS_KEY=
POLL_BATCH_LIMIT=100
POLL_MAX_BATCH_SIZE=50
POLL_MAX_CONCURRENT=3
POLL_INTER_BATCH_DELAY_MS=0
SYNC_UPSERT_CONCURRENCY=10
PROVIDER_PRICE_CACHE_TTL_MS=300000

# Development smoke seed
# Run with: npm run seed:smoke
# Defaults are development-only. Override passwords in shared dev environments.
SMOKE_ADMIN_EMAIL=smoke.admin@example.com
SMOKE_ADMIN_PASSWORD=SmokeAdmin123!
SMOKE_ADMIN_NAME=Smoke Admin
SMOKE_CUSTOMER_EMAIL=smoke.customer@example.com
SMOKE_CUSTOMER_PASSWORD=SmokeCustomer123!
SMOKE_CUSTOMER_NAME=Smoke Active Customer
SMOKE_PENDING_CUSTOMER_EMAIL=smoke.pending@example.com
SMOKE_PENDING_CUSTOMER_PASSWORD=SmokePending123!
SMOKE_PENDING_CUSTOMER_NAME=Smoke Pending Customer
SMOKE_EGP_PLATFORM_RATE=50
SMOKE_VODAFONE_CASH_NUMBER=01000000000
SMOKE_VODAFONE_CASH_OWNER=Smoke Test Wallet

# Optional provider smoke seed. Leave blank unless using a safe dev provider.
SMOKE_PROVIDER_NAME=
SMOKE_PROVIDER_BASE_URL=
SMOKE_PROVIDER_API_TOKEN=
SMOKE_PROVIDER_ACTIVE=false

# Strongly discouraged. Smoke seed refuses production unless this is explicit.
ALLOW_PRODUCTION_SEED=false
